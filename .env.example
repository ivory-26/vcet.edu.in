# Backend API base URL (NO /api suffix — '/api' is appended by client helpers)
# Development: http://localhost:8000
# Production:  https://vcet.edu.in
VITE_API_URL=http://localhost:8000

# Legacy fallback key still used by some modules
VITE_API_BASE_URL=http://localhost:8000

# Frontend-only development flags
VITE_MOCK_AUTH=false
VITE_DEV_BYPASS=false

# Frontend public-data cache switch (independent of admin/backend logic)
# true  -> enable localStorage + in-memory cache in hooks
# false -> disable hook cache and always fetch fresh data
VITE_ENABLE_PUBLIC_CACHE=true

# Optional: persistent page-data cache tuning (in milliseconds)
# Default TTL: 600000 (10 minutes)
# Default revalidate window: 60000 (1 minute)
VITE_PAGE_CACHE_TTL_MS=600000
VITE_PAGE_CACHE_REVALIDATE_MS=60000
